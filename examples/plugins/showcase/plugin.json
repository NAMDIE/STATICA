{
  "id": "acme.showcase",
  "name": "Showcase",
  "version": "1.0.0",
  "apiVersion": 1,
  "description": "End-to-end demo plugin — exercises every plugin SDK surface: admin app, server routes, hooks, canvas modules, frontend tracker, and a Visual Component pack.",
  "permissions": [
    "admin.navigation",
    "cms.storage",
    "cms.routes",
    "cms.hooks",
    "editor.toolbar",
    "editor.commands",
    "modules.register",
    "visualComponents.register",
    "frontend.scripts",
    "frontend.tracker"
  ],
  "entrypoints": {
    "server": "server/index.js",
    "editor": "editor/index.js",
    "modules": "modules/index.js",
    "frontend": "frontend/tracker.js"
  },
  "resources": [
    {
      "id": "events",
      "title": "Tracker Events",
      "singularLabel": "Event",
      "pluralLabel": "Events",
      "fields": [
        { "id": "name", "label": "Event", "type": "text", "required": true },
        { "id": "page", "label": "Page", "type": "text" },
        { "id": "visitor", "label": "Visitor", "type": "text" },
        { "id": "session", "label": "Session", "type": "text" },
        { "id": "payload", "label": "Payload", "type": "longtext" },
        { "id": "received-at", "label": "Received At", "type": "date" }
      ]
    }
  ],
  "adminPages": [
    {
      "id": "dashboard",
      "title": "Showcase",
      "navLabel": "Showcase",
      "icon": "box-stack",
      "content": {
        "kind": "app",
        "heading": "Showcase Plugin",
        "entry": "admin/dashboard.js"
      }
    },
    {
      "id": "events",
      "title": "Tracker Events",
      "navLabel": "Events",
      "content": {
        "kind": "resource",
        "heading": "Tracker Events",
        "resource": "events"
      }
    }
  ],
  "pack": {
    "path": "pack/site.json"
  }
}
